NODE_ENV=development

# Required provider credentials (set real values locally; never commit secrets)
JQUANTS_API_KEY=your_jquants_api_key
EDINET_API_KEY=your_edinet_api_key
ESTAT_APP_ID=your_estat_app_id

# Optional/legacy tokens
JQUANTS_ID_TOKEN=

# Verification and model runtime
VERIFY_TARGETS=jquants,kabucom,edinet,estat
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1

# Input channel options for autonomous search
UQTL_INPUT_CHANNEL=task
UQTL_NL_INPUT=
UQTL_NL_INPUT_FILE=

HF_KEY = hf_