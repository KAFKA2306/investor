{
  "name": "ts-agent",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "lint": "biome check src",
    "format": "biome format src --write",
    "start": "bun src/index.ts",
    "start:api": "bun src/providers/uqtl_event_api_server.ts",
    "verify:api": "bun src/system/app_runtime_core.ts",
    "experiments:alpha-discovery": "bun src/experiments/alpha_mining_experiments.ts",
    "experiments:kb-build": "bun src/experiments/build_alpha_knowledgebase.ts",
    "experiments:kb-backtest": "bun src/experiments/run_kb_signal_backtest.ts",
    "experiments:kb-plot": "python3 src/experiments/plot_kb_signal_backtest.py",
    "experiments:10k-features": "bun src/experiments/generate_10k_features.ts",
    "experiments:build-edinet-event-features": "bun src/experiments/generate_10k_features.ts",
    "experiments:build-macro-regime": "bun src/experiments/build_macro_regime.ts",
    "experiments:run-edinet-regime-backtest": "bun src/experiments/run_kb_signal_backtest.ts --with-gates",
    "experiments:repair-edinet-event-features": "bun src/experiments/repair_edinet_event_features.ts",
    "experiments:verify-edinet-io": "bun src/experiments/verify_edinet_io_contract.ts",
    "experiments:verification-json": "bun src/experiments/quantitative_performance_proof.ts",
    "experiments:verification-plot": "uv run python src/experiments/plot_generator.py",
    "pipeline:ab": "bun src/pipeline/evaluate/backtest_core.ts",
    "pipeline:mine": "bun src/pipeline/factor_mining/mining_core.ts",
    "pipeline:backtest": "bun src/pipeline/evaluate/backtest_core.ts",
    "edinet": "bun scripts/edinet_cli.ts",
    "edinet:tickers": "bun scripts/edinet_tickers.ts",
    "jquants:warm-cache": "bun scripts/jquants_cache_warm.ts",
    "db:test": "bun src/db/scripts/test_postgres_connection.ts",
    "db:migrate": "bun src/db/scripts/migrate_to_postgres.ts"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.2",
    "express": "^5.2.1",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "vite": "^7.3.1"
  },
  "peerDependencies": {},
  "dependencies": {
    "@google/genai": "^1.43.0",
    "apache-arrow": "^21.1.0",
    "js-yaml": "^4.1.1",
    "pg": "^8.19.0",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}