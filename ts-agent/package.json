  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "apache-arrow": "^21.1.0",
    "js-yaml": "^4.1.1",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}
