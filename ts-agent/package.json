{
  "name": "ts-agent",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format src --write",
    "start": "bun src/index.ts",
    "verify:api": "bun src/experiments/api_verify.ts",
    "verify:scenario": "bun src/experiments/01_vegetable.ts",
    "experiments:comparison": "bun src/experiments/02_comparison.ts",
    "experiments:timeseries": "bun src/experiments/03_timeseries_analysis.ts",
    "experiments:benchmark": "bun src/experiments/04_foundation_benchmark.ts",
    "pipeline:evaluate": "bun src/pipeline/evaluate/foundation_benchmark.ts",
    "pipeline:ab": "bun src/pipeline/evaluate/ab_compare_daily_logs.ts",
    "pipeline:llm-readiness": "bun src/pipeline/evaluate/llm_agent_readiness.ts",
    "pipeline:mine": "bun src/pipeline/factor_mining/evolve_candidates.ts",
    "pipeline:full-validation": "bun src/pipeline/evaluate/run_full_validation.ts"
